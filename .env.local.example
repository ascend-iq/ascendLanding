# Resend — get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Where contact form submissions are emailed to (your team inbox)
CONTACT_EMAIL_TO=team@ascendiq.com

# The "from" address — must be a verified domain in Resend
# During development, Resend's default sandbox sender (onboarding@resend.dev) works without domain verification
# For production, verify your domain at https://resend.com/domains and use e.g.:
# CONTACT_EMAIL_FROM=AscendIQ <no-reply@ascendiq.com>
CONTACT_EMAIL_FROM=AscendIQ <onboarding@resend.dev>

# Resend Audiences — create separate lists per audience at https://resend.com/audiences
# Each audience type routes to its own list for targeted follow-up campaigns.
# If per-type IDs are missing, falls back to RESEND_AUDIENCE_ID (general list).
RESEND_AUDIENCE_ID=           # general / fallback
RESEND_AUDIENCE_ID_SCHOOLS=   # school admins & districts
RESEND_AUDIENCE_ID_PARENTS=   # parents enrolling students
RESEND_AUDIENCE_ID_EMPLOYERS= # employer / industry partners

# Square — from your Square Developer Dashboard (developer.squareup.com)
# These NEXT_PUBLIC_ vars are safe to expose — they only identify your app, not authorize charges
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-...
NEXT_PUBLIC_SQUARE_LOCATION_ID=...
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox   # change to "production" when going live

# Server-side only — never expose this publicly
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=...                   # same value as NEXT_PUBLIC_SQUARE_LOCATION_ID
SQUARE_ENVIRONMENT=sandbox

# DynamoDB — enrollment storage (optional; payment still succeeds if unset)
# AWS Console → DynamoDB → Create table: ascend-enrollments
# Partition key: id (String) | Capacity: On-demand
# Amplify blocks vars starting with "AWS_" — use DYNAMODB_* names below
DYNAMODB_REGION=us-east-1
DYNAMODB_ENROLLMENTS_TABLE=ascend-enrollments
# When not using IAM role (e.g. local dev or Amplify with access keys):
# DYNAMODB_ACCESS_KEY_ID=...
# DYNAMODB_SECRET_ACCESS_KEY=...

# LMS enrollment handoff — called after successful Square payment
# Internal URL of the Go API (not publicly exposed)
LMS_INTERNAL_URL=http://localhost:8080
# Must match ENROLL_SECRET in the LMS .env
ENROLL_SECRET=change-me-to-a-random-64-char-hex-string
